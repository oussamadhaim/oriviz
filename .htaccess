# Activer la réécriture d'URL
RewriteEngine On

# Forcer HTTPS (recommandé pour Hostinger)
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Redirection interne pour les pages de produits dynamiques
# /products/quelque-chose -> /product.html
RewriteRule ^products/([^/]+)/?$ product.html [NC,L]

# Supprimer l'extension .html des URL de manière externe
# Exemple: oriviz.com/about.html -> oriviz.com/about
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.html [NC]
RewriteRule ^ %1 [R=301,L]

# Si la requête ne correspond pas à un dossier existant
RewriteCond %{REQUEST_FILENAME} !-d
# Et si la requête correspond au fichier avec .html ajouté
RewriteCond %{REQUEST_FILENAME}.html -f
# Alors réécrire la requête en interne vers le fichier .html
RewriteRule ^([^\.]+)$ $1.html [NC,L]

# Gestion des erreurs 404
ErrorDocument 404 /index.html
